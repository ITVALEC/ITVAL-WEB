{
  "name": "itval-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node scripts/clean-next.js --force && node scripts/free-port.js 3000 && next dev -p 3000",
    "catalog:i18n": "node scripts/generate-products-catalog.mjs",
    "catalog:validate-filters": "npx tsx scripts/validate-product-filters.mjs",
    "images:placeholders": "node scripts/create-image-placeholders.mjs",
    "images:import": "node scripts/import-product-photos.mjs",
    "images:projects": "node scripts/import-portfolio-projects.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgrest db",
    "db:schema": "node scripts/apply-schema.mjs",
    "db:migrate": "node scripts/migrate-json-to-postgres.mjs",
    "db:export": "node scripts/export-postgres-to-json.mjs",
    "db:setup": "node scripts/apply-schema.mjs && node scripts/migrate-json-to-postgres.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.1.0",
    "next-intl": "^3.26.0",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
