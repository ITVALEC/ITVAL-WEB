# ─── PostgreSQL (fuente principal en VPS / local) ─────────────────
# En cPanel/VPS usa la URL de tu Postgres del servidor.
# Ejemplo VPS: postgres://usuario:clave@127.0.0.1:5432/itval
DATABASE_URL=postgres://postgres:tu_contraseña@localhost:5432/itval_db

# Alternativa por piezas (si no usas DATABASE_URL):
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=itval_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_contraseña

# ─── Panel admin (OBLIGATORIO en producción / Netlify / cPanel) ───
# Copia este archivo a `.env.local` en tu máquina (no se sube a GitHub).
# En el hosting define las mismas variables en el panel de entorno.
#
# Local (desarrollo): si no defines ADMIN_PASSWORD, el default es itval2026.
# Producción: DEBES definir ADMIN_PASSWORD y ADMIN_SECRET o el login no funcionará.
ADMIN_PASSWORD=cambia_esta_contraseña
ADMIN_SECRET=cambia_este_secreto_largo_aleatorio

# ─── MongoDB Atlas (opcional — no poner en VPS si usas Postgres) ──
# MONGODB_URI=mongodb+srv://usuario:clave@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=itval
